# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-with-openai-api-key

# --- Meta / WhatsApp Cloud API ------------------------------------------------
WA_PHONE_NUMBER_ID=replace-with-phone-number-id
WA_BUSINESS_ACCOUNT_ID=replace-with-business-account-id
WA_ACCESS_TOKEN=replace-with-wa-access-token
WA_VERIFY_TOKEN=replace-with-verify-token
WA_API_VERSION=v21.0

# --- Servidor -----------------------------------------------------------------
PORT=5001
NODE_ENV=development

# --- ERP / Agenda -------------------------------------------------------------
ERP_BASE_URL=http://localhost:3000
ERP_API_TOKEN=replace-with-erp-api-token
ERP_TENANT_SLUG=clinica-bella
TIMEZONE=America/Sao_Paulo

# --- Receps internal API (opt-out etc.) ---------------------------------------
RECEPS_INTERNAL_API_URL=http://localhost:3000
